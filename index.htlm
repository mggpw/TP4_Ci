<!-- FINAL -->
<section class="card final-card" id="final">
  <h2>🎓 Tu avance en el TP4</h2>
  <div class="final-stat" id="finalStat">0%</div>
  <p id="finalText">Completá los 17 ejercicios para terminar el Trabajo Práctico N°4.</p>
</section>

</main>

<footer>Basado en: Seminario Nivelatorio de Matemática — INSPT, Universidad Tecnológica Nacional · Unidad 4: Funciones</footer>

<script>
/* =====================================================================
   ARQUITECTURA OPTIMIZADA
   - 1 solo listener de click delegado (en vez de ~150+ listeners individuales)
   - Construcción perezosa (lazy) de cada ejercicio vía IntersectionObserver:
     el HTML/SVG pesado de un ejercicio recién se genera cuando el usuario
     está por llegar a esa sección, no todo de una al cargar la página.
   - content-visibility:auto en cada tarjeta: el navegador ni siquiera
     calcula layout/paint de las secciones fuera de pantalla.
   - Grillas de los gráficos con <pattern> SVG (costo O(1) en nodos del DOM,
     en vez de una <line> + <text> por cada unidad del eje).
   - Construcción de HTML con arrays + join() en vez de concatenación
     repetida de strings.
   ===================================================================== */

const $  = (s,p=document)=>p.querySelector(s);
const $all = (s,p=document)=>[...p.querySelectorAll(s)];
const TOTAL = 17;
const done = new Set();

/* ---------- utilidades numéricas ---------- */
function parseNum(str){
  if(typeof str !== 'string') return NaN;
  str = str.trim().replace(',', '.');
  if(str==='') return NaN;
  if(str.includes('/')){
    const parts = str.split('/');
    if(parts.length!==2) return NaN;
    const n=parseFloat(parts[0]), d=parseFloat(parts[1]);
    if(isNaN(n)||isNaN(d)||d===0) return NaN;
    return n/d;
  }
  return parseFloat(str);
}
function extractNumbers(str){
  if(typeof str!=='string') return [];
  const norm = str.replace(',', '.');
  const matches = norm.match(/-?\d+(\.\d+)?(\/\d+(\.\d+)?)?/g) || [];
  return matches.map(parseNum).filter(n=>!isNaN(n));
}

/* ---------- progreso ---------- */
function markDone(n){
  if(done.has(n)) return;
  done.add(n);
  const link = $('#toc a[data-n="'+n+'"]');
  if(link) link.classList.add('done');
  updateProgress();
}
function updateProgress(){
  const pct = Math.round(done.size/TOTAL*100);
  $('#progressFill').style.width = pct+'%';
  $('#progressLabel').textContent = done.size+' / '+TOTAL;
  $('#finalStat').textContent = pct+'%';
  const t = $('#finalText');
  if(pct===0) t.textContent='Completá los 17 ejercicios para terminar el Trabajo Práctico N°4.';
  else if(pct<50) t.textContent='¡Buen arranque! Seguí practicando con los siguientes ejercicios.';
  else if(pct<100) t.textContent='¡Vas muy bien! Ya resolviste más de la mitad del TP4.';
  else t.textContent='¡Completaste todo el TP4 de Funciones! 🎉 Gran trabajo.';
}
function buildToc(){
  const parts=[];
  for(let i=1;i<=17;i++) parts.push('<a href="#ej'+i+'" data-n="'+i+'">'+i+'</a>');
  $('#toc').innerHTML = parts.join('');
}
function showMsg(id, success, text){
  const el = document.getElementById(id);
  if(!el) return;
  el.style.display='block';
  el.className='feedback-msg '+(success?'success':'error');
  el.textContent=text;
}
function finish(n, results, msgId){
  const all = results.every(Boolean);
  showMsg(msgId, all, all?'¡Excelente! Todas las respuestas son correctas. 🎉':'Revisá los campos marcados en rojo y volvé a intentarlo.');
  markDone(n);
}

/* ---------- helpers de evaluación (sin listeners propios: la UI se
   resuelve toda con el único listener delegado de más abajo) ---------- */
function choiceMarkup(id, options, correctVal, immediate){
  const btns = options.map(o=>'<button type="button" class="choice-btn" data-val="'+o.val+'">'+o.label+'</button>').join('');
  return '<div class="choice-group" id="'+id+'" data-correct="'+correctVal+'"'+(immediate?' data-immediate="1"':'')+'>'+btns+'</div>';
}
function fillChoice(container, options, correctVal, immediate){
  if(!container) return;
  container.dataset.correct = correctVal;
  if(immediate) container.dataset.immediate = '1';
  container.innerHTML = options.map(o=>'<button type="button" class="choice-btn" data-val="'+o.val+'">'+o.label+'</button>').join('');
}
function evalChoice(container){
  const sel = container.dataset.selected;
  const correct = container.dataset.correct;
  const ok = sel===correct;
  $all('.choice-btn',container).forEach(b=>{
    b.classList.remove('correct','incorrect');
    if(b.dataset.val===correct) b.classList.add('correct');
    else if(b.dataset.val===sel && !ok) b.classList.add('incorrect');
  });
  return ok;
}
function evalNumeric(input, correctVal, tol=0.05){
  const val = parseNum(input.value);
  const ok = !isNaN(val) && Math.abs(val-correctVal)<=tol;
  input.classList.remove('correct','incorrect');
  input.classList.add(ok?'correct':'incorrect');
  return ok;
}
function evalSet(inputs, correctArr, tol=0.02){
  const vals = inputs.map(i=>parseNum(i.value));
  const used = Array(correctArr.length).fill(false);
  let allMatched = true;
  vals.forEach(v=>{
    if(isNaN(v)){ allMatched=false; return; }
    const idx = correctArr.findIndex((c,i)=>!used[i] && Math.abs(c-v)<tol);
    if(idx>=0) used[idx]=true; else allMatched=false;
  });
  const ok = allMatched && used.every(u=>u);
  inputs.forEach(i=>{ i.classList.remove('correct','incorrect'); i.classList.add(ok?'correct':'incorrect'); });
  return ok;
}

/* ---------- gráficos SVG livianos (grilla con <pattern>, O(1) nodos) ---------- */
let pgCounter = 0;
function niceStep(range){ if(range<=14) return 1; if(range<=30) return 2; if(range<=70) return 5; return 10; }
function renderGraph(container, cfg){
  if(!container) return;
  const {xmin,xmax,ymin,ymax,segments=[],points=[]} = cfg;
  const width = cfg.width||300, height=cfg.height||210;
  const sx = x => (x-xmin)/(xmax-xmin)*width;
  const sy = y => height-(y-ymin)/(ymax-ymin)*height;
  const xStep = niceStep(xmax-xmin), yStep = niceStep(ymax-ymin);
  const stepXpx = xStep/(xmax-xmin)*width;
  const stepYpx = yStep/(ymax-ymin)*height;
  const uid = 'pg'+(pgCounter++);
  const axisX = sy(0), axisY = sx(0);
  const xLabelY = axisX > height-16 ? height-4 : axisX+12;
  const yEdge = axisY < 16;
  const yLabelX = yEdge ? 3 : axisY-5;
  const yAnchor = yEdge ? 'start' : 'end';

  const parts = [
    '<svg viewBox="0 0 '+width+' '+height+'" class="mini-plane">',
    '<defs><pattern id="'+uid+'" width="'+stepXpx+'" height="'+stepYpx+'" patternUnits="userSpaceOnUse">',
    '<path d="M '+stepXpx+' 0 L 0 0 0 '+stepYpx+'" fill="none" stroke="#dde3f0" stroke-width="1"/></pattern></defs>',
    '<rect width="'+width+'" height="'+height+'" fill="#f8f9ff"/>',
    '<rect width="'+width+'" height="'+height+'" fill="url(#'+uid+')"/>'
  ];
  if(ymin<=0&&ymax>=0) parts.push('<line x1="0" y1="'+axisX+'" x2="'+width+'" y2="'+axisX+'" stroke="#64748b" stroke-width="2"/>');
  if(xmin<=0&&xmax>=0) parts.push('<line x1="'+axisY+'" y1="0" x2="'+axisY+'" y2="'+height+'" stroke="#64748b" stroke-width="2"/>');
  for(let x=xmin; x<=xmax+1e-9; x+=xStep){
    const xr=Math.round(x*100)/100;
    if(Math.abs(xr)>1e-9) parts.push('<text x="'+sx(xr)+'" y="'+xLabelY+'" font-size="9" fill="#64748b" text-anchor="middle">'+xr+'</text>');
  }
  for(let y=ymin; y<=ymax+1e-9; y+=yStep){
    const yr=Math.round(y*100)/100;
    if(Math.abs(yr)>1e-9) parts.push('<text x="'+yLabelX+'" y="'+(sy(yr)+3)+'" font-size="9" fill="#64748b" text-anchor="'+yAnchor+'">'+yr+'</text>');
  }
  if(segments.length){
    const d=segments.map((p,i)=>(i===0?'M':'L')+sx(p[0]).toFixed(1)+','+sy(p[1]).toFixed(1)).join(' ');
    parts.push('<path d="'+d+'" fill="none" stroke="#3b82f6" stroke-width="2.5"/>');
  }
  points.forEach(p=>parts.push('<circle cx="'+sx(p[0])+'" cy="'+sy(p[1])+'" r="3.5" fill="#00d4aa"/>'));
  parts.push('</svg>');
  container.innerHTML = parts.join('');
}
function sampleLinear(m,b,xmin,xmax){ return [[xmin, m*xmin+b],[xmax, m*xmax+b]]; }
function sampleQuad(a,h,k,xmin,xmax,n=34){
  const pts=[];
  for(let i=0;i<=n;i++){ const x=xmin+(xmax-xmin)*i/n; pts.push([x, a*(x-h)*(x-h)+k]); }
  return pts;
}

/* =====================================================================
   DATOS Y CONSTRUCTORES DE CADA EJERCICIO (sin cambios respecto del TP)
   ===================================================================== */

/* ---- 1 ---- */
function buildEj1(){
  const cardsData = [
    {txt:'Kilos de manzana comprados → precio total a pagar', ans:'fn'},
    {txt:'Un nombre → las personas que tienen ese nombre', ans:'nofn'},
    {txt:'Cada persona → el país donde nació', ans:'fn'}
  ];
  $('#ej1-cards').innerHTML = cardsData.map((c,i)=>
    '<div class="drag-card" data-ans="'+c.ans+'" data-id="c'+i+'">'+c.txt+'</div>'
  ).join('');
}

/* ---- 2 ---- */
function buildEj2(){
  const yn = [{label:'Sí, es función',val:'si'},{label:'No es función',val:'no'}];
  fillChoice($('#g2a'), yn, 'no', true);
  fillChoice($('#g2b'), yn, 'si', true);
  fillChoice($('#g2c'), yn, 'no', true);
  fillChoice($('#g2d'), yn, 'si', true);
}

/* ---- 3 ---- */
function buildEj3(){
  fillChoice($('#e3a-expr'), [{label:'y = x³',val:'a'},{label:'y = 3x',val:'b'},{label:'y = x/3',val:'c'},{label:'y = x²',val:'d'}], 'a');
  fillChoice($('#e3a-dom'), [{label:'ℝ',val:'a'},{label:'ℤ',val:'b'},{label:'ℕ',val:'c'},{label:'ℝ⁺',val:'d'}], 'a');
  fillChoice($('#e3b-expr'), [{label:'y = 2x + 1',val:'a'},{label:'y = 2x',val:'b'},{label:'y = x + 1',val:'c'},{label:'y = 2(x+1)',val:'d'}], 'a');
  fillChoice($('#e3b-dom'), [{label:'ℤ',val:'a'},{label:'ℝ',val:'b'},{label:'ℕ',val:'c'},{label:'ℚ',val:'d'}], 'a');
  fillChoice($('#e3b-y1'), [{label:'Sí, está definida',val:'si'},{label:'No pertenece al dominio',val:'no'}], 'no');
}
function checkEj3(){
  const r=[
    evalChoice($('#e3a-expr')), evalChoice($('#e3a-dom')),
    evalNumeric($('#e3a-y1'), -0.125, 0.01), evalNumeric($('#e3a-y2'), 0, 0.01), evalNumeric($('#e3a-y3'), 1, 0.01),
    evalChoice($('#e3b-expr')), evalChoice($('#e3b-dom')), evalChoice($('#e3b-y1')),
    evalNumeric($('#e3b-y2'), 1, 0.01), evalNumeric($('#e3b-y3'), 3, 0.01)
  ];
  finish(3, r, 'e3-msg');
}

/* ---- 4 ---- */
function buildEj4(){
  fillChoice($('#e4d'), [{label:'Sí',val:'si'},{label:'No',val:'no'}], 'no');
}
function checkEj4(){
  const r=[
    evalNumeric($('#e4a'), 7),
    evalSet([$('#e4b-x1'),$('#e4b-x2')], [0,0.5]),
    evalNumeric($('#e4c'), 4),
    evalChoice($('#e4d'))
  ];
  finish(4, r, 'e4-msg');
}

/* ---- 5 ---- */
function buildEj5(){
  renderGraph($('#e5-graph'), {xmin:-4,xmax:6,ymin:-6,ymax:6, segments:[[-4,6],[1,-4],[6,6]], points:[[-1,0],[0,-2],[3,0]]});
  fillChoice($('#e5a'), [{label:'ℝ',val:'a'},{label:'[0,+∞)',val:'b'},{label:'ℤ',val:'c'},{label:'ℝ−{0}',val:'d'}], 'a');
  fillChoice($('#e5d'), [{label:'Sí',val:'si'},{label:'No',val:'no'}], 'si');
  fillChoice($('#e5f'), [{label:'[−4,+∞)',val:'a'},{label:'(−∞,−4]',val:'b'},{label:'ℝ',val:'c'},{label:'[0,+∞)',val:'d'}], 'a');
  fillChoice($('#e5h'), [{label:'Sí',val:'si'},{label:'No',val:'no'}], 'si');
}
function checkEj5(){
  const r=[
    evalChoice($('#e5a')),
    evalSet([$('#e5b-x1'),$('#e5b-x2')], [-1,3]),
    evalNumeric($('#e5c'), 2),
    evalChoice($('#e5d')),
    evalSet([$('#e5d-x1'),$('#e5d-x2')], [0.5,1.5], 0.15),
    evalNumeric($('#e5e'), -2),
    evalChoice($('#e5f')),
    evalNumeric($('#e5g'), -1),
    evalChoice($('#e5h'))
  ];
  finish(5, r, 'e5-msg');
}

/* ---- 6 ---- */
function buildEj6(){
  fillChoice($('#e6a'), [{label:'ℝ',val:'a'},{label:'ℝ−{0}',val:'b'},{label:'ℝ⁺',val:'c'},{label:'ℤ−{0}',val:'d'}], 'b');
  fillChoice($('#e6c'), [{label:'Sí',val:'si'},{label:'No',val:'no'}], 'no');
}
function checkEj6(){
  const r=[
    evalChoice($('#e6a')),
    evalNumeric($('#e6b'), 1/3, 0.01),
    evalChoice($('#e6c')),
    evalNumeric($('#e6d-y1'), -4/3, 0.02),
    evalNumeric($('#e6d-y2'), -1, 0.01),
    evalNumeric($('#e6d-y3'), 0.5, 0.01)
  ];
  finish(6, r, 'e6-msg');
}

/* ---- 7 ---- */
function buildEj7(){
  fillChoice($('#e7a'), [{label:'p = 4500c',val:'a'},{label:'p = c/4500',val:'b'},{label:'p = 4500 + c',val:'c'},{label:'c = 4500p',val:'d'}], 'a');
  fillChoice($('#e7b-fn'), [{label:'Sí',val:'si'},{label:'No',val:'no'}], 'si');
  fillChoice($('#e7b-dom'), [{label:'(0,+∞)',val:'a'},{label:'ℝ',val:'b'},{label:'[0,+∞)',val:'c'},{label:'ℤ⁺',val:'d'}], 'a');
}
function checkEj7(){
  const r=[
    evalChoice($('#e7a')), evalChoice($('#e7b-fn')), evalChoice($('#e7b-dom')),
    evalNumeric($('#e7c'), 1.65, 0.02)
  ];
  finish(7, r, 'e7-msg');
}

/* ---- 8 ---- */
function buildEj8(){
  fillChoice($('#e8a'), [{label:'d = 8,2t',val:'a'},{label:'d = t/8,2',val:'b'},{label:'d = 8,2 + t',val:'c'},{label:'t = 8,2d',val:'d'}], 'a');
}
function checkEj8(){
  const r=[ evalChoice($('#e8a')), evalNumeric($('#e8b'), 8.2/3, 0.05) ];
  finish(8, r, 'e8-msg');
  renderGraph($('#e8-graph'), {xmin:0,xmax:3,ymin:0,ymax:25,segments: sampleLinear(8.2,0,0,3)});
}

/* ---- 9 ---- */
function buildEj9(){
  renderGraph($('#e9-graph'), {xmin:0,xmax:8,ymin:0,ymax:20,segments:[[0,0],[2,4],[4.5,12],[7,17]],points:[[2,4],[4.5,12]]});
  fillChoice($('#e9a'), [{label:'[0,7]',val:'a'},{label:'[0,+∞)',val:'b'},{label:'ℝ',val:'c'},{label:'(0,7)',val:'d'}], 'a');
}
function checkEj9(){
  const r=[
    evalChoice($('#e9a')),
    evalNumeric($('#e9b'), 4, 0.1),
    evalNumeric($('#e9c'), 4.5, 0.1),
    evalNumeric($('#e9d'), 17, 0.1)
  ];
  finish(9, r, 'e9-msg');
}

/* ---- 10 ---- */
const ej10Data = [
  {label:'a) f(x) = 3x + 1', m:3, b:1, intX:-1/3, intY:1, crec:'creciente', f3:-8},
  {label:'b) f(x) = −2x − 4', m:-2, b:-4, intX:-2, intY:-4, crec:'decreciente', f3:2},
  {label:'c) f(x) = 2 − x', m:-1, b:2, intX:2, intY:2, crec:'decreciente', f3:5},
  {label:'d) f(x) = (2/3)x + 6', m:2/3, b:6, intX:-9, intY:6, crec:'creciente', f3:4}
];
function buildEj10(){
  const html = ej10Data.map((it,i)=>
    '<div class="item-block"><div class="func-label">'+it.label+'</div>'+
    '<div id="g10-'+i+'"></div>'+
    '<div class="field-row"><label>Intersección eje x:</label><input class="ans-input" id="e10-'+i+'-ix"></div>'+
    '<div class="field-row"><label>Intersección eje y:</label><input class="ans-input" id="e10-'+i+'-iy"></div>'+
    '<div class="field-row"><label>Pendiente:</label><input class="ans-input" id="e10-'+i+'-m"></div>'+
    '<div class="field-row"><label>Ordenada al origen:</label><input class="ans-input" id="e10-'+i+'-b"></div>'+
    '<div class="field-row"><label>¿Crece, decrece o es constante?</label><div class="choice-group" id="e10-'+i+'-c"></div></div>'+
    '<div class="field-row"><label>f(−3):</label><input class="ans-input" id="e10-'+i+'-f3"></div></div>'
  ).join('');
  $('#ej10-body').innerHTML = html;
  ej10Data.forEach((it,i)=>{
    renderGraph($('#g10-'+i), {xmin:-5,xmax:5,ymin:-16,ymax:16,segments:sampleLinear(it.m,it.b,-5,5)});
    fillChoice($('#e10-'+i+'-c'), [{label:'Creciente',val:'creciente'},{label:'Decreciente',val:'decreciente'},{label:'Constante',val:'constante'}], it.crec);
  });
}
function checkEj10(){
  let r=[];
  ej10Data.forEach((it,i)=>{
    r.push(evalNumeric($('#e10-'+i+'-ix'), it.intX, 0.05));
    r.push(evalNumeric($('#e10-'+i+'-iy'), it.intY, 0.05));
    r.push(evalNumeric($('#e10-'+i+'-m'), it.m, 0.02));
    r.push(evalNumeric($('#e10-'+i+'-b'), it.b, 0.02));
    r.push(evalChoice($('#e10-'+i+'-c')));
    r.push(evalNumeric($('#e10-'+i+'-f3'), it.f3, 0.05));
  });
  finish(10, r, 'e10-msg');
}

/* ---- 11 ---- */
const ej11Data = [
  {label:'a) Pendiente 4, ordenada al origen −1', m:4, b:-1},
  {label:'b) Pendiente 5, pasa por (−1; 3)', m:5, b:8},
  {label:'c) Ordenada al origen 3, pasa por (1; 5)', m:2, b:3},
  {label:'d) Es horizontal y pasa por (1; 2)', m:0, b:2},
  {label:'e) Ordenada al origen −2, raíz x = 4', m:0.5, b:-2},
  {label:'f) Paralela a y = 2x + 1, pasa por (−1; 2)', m:2, b:4},
  {label:'g) Perpendicular a y = −3x − 5, pasa por (6; 3)', m:1/3, b:1}
];
function buildEj11(){
  $('#ej11-body').innerHTML = ej11Data.map((it,i)=>
    '<div class="item-block"><p class="sub">'+it.label+'</p>'+
    '<div class="field-row"><label>y = </label>'+
    '<input class="ans-input" id="e11-'+i+'-m" style="width:70px" placeholder="m"> · x + '+
    '<input class="ans-input" id="e11-'+i+'-b" style="width:70px" placeholder="b"></div></div>'
  ).join('');
}
function checkEj11(){
  let r=[];
  ej11Data.forEach((it,i)=>{
    r.push(evalNumeric($('#e11-'+i+'-m'), it.m, 0.02));
    r.push(evalNumeric($('#e11-'+i+'-b'), it.b, 0.02));
  });
  finish(11, r, 'e11-msg');
}

/* ---- 12 ---- */
const ej12Data = [
  {label:'a) f(x) = −2x² + 3x − 1', a:-2,h:0.75,k:0.125, roots:[0.5,1], intY:-1, dir:'max', xr:[-1,2.5],yr:[-3,1],
   miss:[
     {name:'Forma canónica', opts:[{t:'f(x) = 2(x − 3/4)² + 1/8',c:false},{t:'f(x) = −2(x − 3/4)² + 1/8',c:true},{t:'f(x) = −2(x + 3/4)² + 1/8',c:false}]},
     {name:'Forma factorizada', opts:[{t:'f(x) = −2(x + 1/2)(x + 1)',c:false},{t:'f(x) = 2(x − 1/2)(x − 1)',c:false},{t:'f(x) = −2(x − 1/2)(x − 1)',c:true}]}
   ]},
  {label:'b) f(x) = 3(x − 2)(x + 4)', a:3,h:-1,k:-27, roots:[-4,2], intY:-24, dir:'min', xr:[-6,4],yr:[-30,10],
   miss:[
     {name:'Forma general', opts:[{t:'f(x) = 3x² + 6x − 24',c:true},{t:'f(x) = 3x² − 6x − 24',c:false},{t:'f(x) = 3x² + 6x + 24',c:false}]},
     {name:'Forma canónica', opts:[{t:'f(x) = 3(x − 1)² − 27',c:false},{t:'f(x) = 3(x + 1)² − 27',c:true},{t:'f(x) = 3(x + 1)² + 27',c:false}]}
   ]},
  {label:'c) f(x) = 2(x − 1)² − 8', a:2,h:1,k:-8, roots:[-1,3], intY:-6, dir:'min', xr:[-3,5],yr:[-10,10],
   miss:[
     {name:'Forma general', opts:[{t:'f(x) = 2x² − 4x − 6',c:true},{t:'f(x) = 2x² + 4x − 6',c:false},{t:'f(x) = 2x² − 4x + 6',c:false}]},
     {name:'Forma factorizada', opts:[{t:'f(x) = 2(x − 1)(x + 3)',c:false},{t:'f(x) = 2(x + 1)(x − 3)',c:true},{t:'f(x) = 2(x + 1)(x + 3)',c:false}]}
   ]},
  {label:'d) f(x) = −(1/3)(x + 2)² + 3', a:-1/3,h:-2,k:3, roots:[-5,1], intY:5/3, dir:'max', xr:[-7,3],yr:[-3,5],
   miss:[
     {name:'Forma general', opts:[{t:'f(x) = −(1/3)x² − (4/3)x + 5/3',c:true},{t:'f(x) = −(1/3)x² + (4/3)x + 5/3',c:false},{t:'f(x) = (1/3)x² − (4/3)x + 5/3',c:false}]},
     {name:'Forma factorizada', opts:[{t:'f(x) = −(1/3)(x + 1)(x + 5)',c:false},{t:'f(x) = −(1/3)(x − 1)(x − 5)',c:false},{t:'f(x) = −(1/3)(x − 1)(x + 5)',c:true}]}
   ]},
  {label:'e) f(x) = −4x + 3x² − 4', a:3,h:2/3,k:-16/3, roots:[-2/3,2], intY:-4, dir:'min', xr:[-2,4],yr:[-7,5],
   miss:[
     {name:'Forma canónica', opts:[{t:'f(x) = 3(x − 2/3)² − 16/3',c:true},{t:'f(x) = 3(x + 2/3)² − 16/3',c:false},{t:'f(x) = 3(x − 2/3)² + 16/3',c:false}]},
     {name:'Forma factorizada', opts:[{t:'f(x) = 3(x − 2/3)(x + 2)',c:false},{t:'f(x) = 3(x + 2/3)(x − 2)',c:true},{t:'f(x) = 3(x − 2/3)(x − 2)',c:false}]}
   ]},
  {label:'f) f(x) = −2(x + 1)(x − 3)', a:-2,h:1,k:8, roots:[-1,3], intY:6, dir:'max', xr:[-3,5],yr:[-5,10],
   miss:[
     {name:'Forma general', opts:[{t:'f(x) = −2x² + 4x + 6',c:true},{t:'f(x) = −2x² − 4x + 6',c:false},{t:'f(x) = 2x² + 4x + 6',c:false}]},
     {name:'Forma canónica', opts:[{t:'f(x) = −2(x + 1)² + 8',c:false},{t:'f(x) = −2(x − 1)² − 8',c:false},{t:'f(x) = −2(x − 1)² + 8',c:true}]}
   ]}
];
function buildEj12(){
  const html = ej12Data.map((it,i)=>{
    let h = '<div class="item-block"><div class="func-label">'+it.label+'</div><div id="g12-'+i+'"></div>'+
      '<div class="field-row"><label>Raíces (eje x):</label><input class="ans-input" id="e12-'+i+'-r1" placeholder="x₁" style="width:70px"><input class="ans-input" id="e12-'+i+'-r2" placeholder="x₂" style="width:70px"></div>'+
      '<div class="field-row"><label>Intersección eje y:</label><input class="ans-input" id="e12-'+i+'-iy" style="width:80px"></div>'+
      '<div class="field-row"><label>Vértice (x;y):</label><input class="ans-input" id="e12-'+i+'-vx" placeholder="x" style="width:70px"><input class="ans-input" id="e12-'+i+'-vy" placeholder="y" style="width:70px"></div>'+
      '<div class="field-row"><label>Conjunto imagen:</label><div class="choice-group" id="e12-'+i+'-im"></div></div>';
    it.miss.forEach((m,mi)=>{ h += '<div class="field-row"><label>'+m.name+':</label></div><div class="choice-group" id="e12-'+i+'-m'+mi+'" style="margin-bottom:6px"></div>'; });
    return h+'</div>';
  }).join('');
  $('#ej12-body').innerHTML = html;
  ej12Data.forEach((it,i)=>{
    renderGraph($('#g12-'+i), {xmin:it.xr[0],xmax:it.xr[1],ymin:it.yr[0],ymax:it.yr[1],segments:sampleQuad(it.a,it.h,it.k,it.xr[0],it.xr[1])});
    const kRound = Math.round(it.k*1000)/1000;
    const imgLabel = it.dir==='min' ? '['+kRound+', +∞)' : '(−∞, '+kRound+']';
    const wrongImg = it.dir==='min' ? '(−∞, '+kRound+']' : '['+kRound+', +∞)';
    fillChoice($('#e12-'+i+'-im'), [{label:imgLabel,val:'ok'},{label:wrongImg,val:'bad'},{label:'ℝ',val:'r'}], 'ok');
    it.miss.forEach((m,mi)=>{
      const opts = m.opts.map((o,oi)=>({label:o.t, val:'o'+oi}));
      const correctVal = 'o'+m.opts.findIndex(o=>o.c);
      fillChoice($('#e12-'+i+'-m'+mi), opts, correctVal);
    });
  });
}
function checkEj12(){
  let r=[];
  ej12Data.forEach((it,i)=>{
    r.push(evalSet([$('#e12-'+i+'-r1'),$('#e12-'+i+'-r2')], it.roots, 0.03));
    r.push(evalNumeric($('#e12-'+i+'-iy'), it.intY, 0.03));
    r.push(evalNumeric($('#e12-'+i+'-vx'), it.h, 0.03));
    r.push(evalNumeric($('#e12-'+i+'-vy'), it.k, 0.03));
    r.push(evalChoice($('#e12-'+i+'-im')));
    it.miss.forEach((m,mi)=> r.push(evalChoice($('#e12-'+i+'-m'+mi))) );
  });
  finish(12, r, 'e12-msg');
}

/* ---- 13 ---- */
function buildEj13(){
  fillChoice($('#e13-quad'), [{label:'Sí',val:'si'},{label:'No',val:'no'}], 'si');
  fillChoice($('#e13-form'), [{label:'General',val:'g'},{label:'Canónica',val:'c'},{label:'Factorizada',val:'f'}], 'f');
  renderGraph($('#e13-graph'), {xmin:0,xmax:20,ymin:0,ymax:110,segments:sampleQuad(-1,10,100,0,20),points:[[10,100]]});
}
function checkEj13(){
  const r=[
    evalChoice($('#e13-quad')), evalChoice($('#e13-form')),
    evalNumeric($('#e13-area'), 64, 0.5), evalNumeric($('#e13-alt'), 16, 0.5), evalNumeric($('#e13-max'), 10, 0.3)
  ];
  finish(13, r, 'e13-msg');
}

/* ---- 14 ---- */
function buildEj14(){
  renderGraph($('#e14-graph'), {xmin:0,xmax:1.5,ymin:0,ymax:10,segments:sampleQuad(-4.9,0,9,0,1.36)});
}
function checkEj14(){
  const r=[ evalNumeric($('#e14a'), 4.1, 0.1), evalNumeric($('#e14b'), 1.355, 0.03) ];
  finish(14, r, 'e14-msg');
}

/* ---- 15 ---- */
const ej15Data = [
  {f:'f(x) = 4x³ − 5x² + 7x − 9', a:4, d:-9},
  {f:'g(x) = −2x³ + 3x² + x − 8', a:-2, d:-8},
  {f:'h(x) = 7x³ − 4x² + 6x', a:7, d:0},
  {f:'p(x) = (3/4)x³ + (1/2)x² − 5x + 2/3', a:0.75, d:2/3},
  {f:'e(x) = 12x³ − 7x² + 9x − 15', a:12, d:-15},
  {f:'k(x) = (5/2)x³ − 6x² + (1/4)x − 7/3', a:2.5, d:-7/3}
];
function buildEj15(){
  const rows = ej15Data.map((it,i)=>
    '<tr><td style="font-family:Consolas,monospace;text-align:left">'+it.f+'</td>'+
    '<td><input class="ans-input" id="e15-'+i+'-a" style="width:80px"></td>'+
    '<td><input class="ans-input" id="e15-'+i+'-d" style="width:80px"></td></tr>'
  ).join('');
  $('#ej15-body').innerHTML = '<table class="fill-table"><tr><th>Función</th><th>Coeficiente principal</th><th>Término independiente</th></tr>'+rows+'</table>';
}
function checkEj15(){
  let r=[];
  ej15Data.forEach((it,i)=>{
    r.push(evalNumeric($('#e15-'+i+'-a'), it.a, 0.02));
    r.push(evalNumeric($('#e15-'+i+'-d'), it.d, 0.02));
  });
  finish(15, r, 'e15-msg');
}

/* ---- 16 ---- */
const ej16Pairs = [
  {id:'L1', left:'(x − 1)(x − 2)(x − 3)', right:'x³ − 6x² + 11x − 6'},
  {id:'L2', left:'2(x − 1)(x − 2)(x − 3)', right:'2x³ − 12x² + 22x − 12'},
  {id:'L3', left:'(x − 2)(x + 2)(x + 3)', right:'x³ + 3x² − 4x − 12'},
  {id:'L4', left:'−(x − 2)(x − 1)(x + 4)', right:'−x³ − x² + 10x − 8'},
  {id:'L5', left:'(x − 1)(x − 2)²', right:'x³ − 5x² + 8x − 4'},
  {id:'L6', left:'(1/2)(x − 2)(x + 2)(x − 3)', right:'(1/2)x³ − (3/2)x² − 2x + 6'}
];
let ej16Selected = null;
let ej16MatchedCount = 0;
function buildEj16(){
  $('#ej16-left').innerHTML  = ej16Pairs.map(p=>'<button type="button" class="match-btn" data-side="left" data-id="'+p.id+'">'+p.left+'</button>').join('');
  const shuffled = [ej16Pairs[3],ej16Pairs[0],ej16Pairs[5],ej16Pairs[1],ej16Pairs[4],ej16Pairs[2]];
  $('#ej16-right').innerHTML = shuffled.map(p=>'<button type="button" class="match-btn" data-side="right" data-match="'+p.id+'">'+p.right+'</button>').join('');
}
function handleMatchClick(btn){
  if(btn.classList.contains('locked')) return;
  if(btn.dataset.side==='left'){
    $all('#ej16-left .match-btn').forEach(b=>b.classList.remove('selected'));
    btn.classList.add('selected');
    ej16Selected = btn.dataset.id;
  } else {
    if(!ej16Selected) return;
    markDone(16);
    const leftBtn = $('#ej16-left .match-btn[data-id="'+ej16Selected+'"]');
    if(btn.dataset.match===ej16Selected){
      btn.classList.add('locked','correct');
      leftBtn.classList.add('locked','correct');
      leftBtn.classList.remove('selected');
      ej16Selected=null;
      ej16MatchedCount++;
      if(ej16MatchedCount===6) showMsg('e16-msg', true, '¡Genial! Relacionaste correctamente las 6 expresiones.');
    } else {
      btn.classList.add('incorrect');
      setTimeout(()=>btn.classList.remove('incorrect'), 600);
    }
  }
}

/* ---- 17 ---- */
const ej17Data = [
  {f:'f(x) = x³ − 6x² + 11x − 6', roots:[1,2,3]},
  {f:'g(x) = x³ − 2x² − 5x + 6', roots:[-2,1,3]},
  {f:'h(x) = x³ + 2x² − 5x − 6', roots:[-3,-1,2]},
  {f:'p(x) = x³ − 3x² − 4x + 12', roots:[-2,2,3]},
  {f:'q(x) = x³ + 4x² + x − 6', roots:[-3,-2,1]},
  {f:'r(x) = 2x³ − 3x² − 11x + 6', roots:[-2,0.5,3]},
  {f:'s(x) = 3x³ − 4x² − 5x + 2', roots:[-1,1/3,2]},
  {f:'t(x) = x³ − 3x² + 4', roots:[-1,2,2]},
  {f:'u(x) = x³ − 3x² − 2x + 8', roots:[2,2.5616,-1.5616]},
  {f:'v(x) = x³ + 5x² + 3x − 9', roots:[-3,-3,1]}
];
function buildEj17(){
  $('#ej17-body').innerHTML = ej17Data.map((it,i)=>
    '<div class="item-block"><div class="func-label">'+it.f+'</div>'+
    '<div class="field-row"><label>Raíces:</label>'+
    '<input class="ans-input" id="e17-'+i+'-r1" placeholder="x₁" style="width:75px">'+
    '<input class="ans-input" id="e17-'+i+'-r2" placeholder="x₂" style="width:75px">'+
    '<input class="ans-input" id="e17-'+i+'-r3" placeholder="x₃" style="width:75px"></div></div>'
  ).join('');
}
function checkEj17(){
  let r=[];
  ej17Data.forEach((it,i)=>{
    const inputs=[$('#e17-'+i+'-r1'),$('#e17-'+i+'-r2'),$('#e17-'+i+'-r3')];
    r.push(evalSet(inputs, it.roots, 0.04));
  });
  finish(17, r, 'e17-msg');
}

/* =====================================================================
   CARGA PEREZOSA (lazy build) + 1 SOLO LISTENER DELEGADO
   ===================================================================== */
const builders = {1:buildEj1,2:buildEj2,3:buildEj3,4:buildEj4,5:buildEj5,6:buildEj6,7:buildEj7,8:buildEj8,9:buildEj9,
                   10:buildEj10,11:buildEj11,12:buildEj12,13:buildEj13,14:buildEj14,15:buildEj15,16:buildEj16,17:buildEj17};
const built = new Set();
function ensureBuilt(n){
  if(built.has(n)) return;
  built.add(n);
  builders[n]();
}
const checkFns = {3:checkEj3,4:checkEj4,5:checkEj5,6:checkEj6,7:checkEj7,8:checkEj8,9:checkEj9,
                   10:checkEj10,11:checkEj11,12:checkEj12,13:checkEj13,14:checkEj14,15:checkEj15,17:checkEj17};

let ej1Selected = null;
function handleDragCardClick(card){
  if(card.classList.contains('placed-correct')||card.classList.contains('placed-wrong')) return;
  $all('.drag-card.selected').forEach(c=>c.classList.remove('selected'));
  card.classList.add('selected');
  ej1Selected = card;
}
function handleDropZoneClick(zone){
  if(!ej1Selected) return;
  const ok = ej1Selected.dataset.ans === zone.dataset.zone;
  ej1Selected.classList.remove('selected');
  ej1Selected.classList.add(ok?'placed-correct':'placed-wrong');
  zone.appendChild(ej1Selected);
  ej1Selected = null;
  const placed = $all('#ej1 .drag-card.placed-correct, #ej1 .drag-card.placed-wrong').length;
  if(placed>=3){
    markDone(1);
    $('#ej1-hint').textContent = 'a) Es función: cada cantidad de kilos tiene un único precio. b) No es función: un mismo nombre puede corresponder a varias personas (no hay unicidad). c) Es función: cada persona nace en un único país.';
  }
}
function handleChoiceClick(btn){
  const group = btn.closest('.choice-group');
  if(!group || group.dataset.locked==='1') return;
  $all('.choice-btn',group).forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
  group.dataset.selected = btn.dataset.val;
  if(group.dataset.immediate==='1'){
    evalChoice(group);
    group.dataset.locked='1';
    const section = group.closest('section.card');
    if(section){
      const idx = section.dataset.idx;
      const groups = $all('.choice-group[data-immediate="1"]', section);
      const lockedCount = $all('.choice-group[data-immediate="1"][data-locked="1"]', section).length;
      if(groups.length && lockedCount===groups.length) markDone(parseInt(idx,10));
    }
  }
}

/* único listener de click para TODA la página */
$('#mainEl').addEventListener('click', function(e){
  const vb = e.target.closest('.verify-btn');
  if(vb){ const fn = checkFns[vb.dataset.check]; if(fn) fn(); return; }

  const mb = e.target.closest('.match-btn');
  if(mb){ handleMatchClick(mb); return; }

  const dc = e.target.closest('.drag-card');
  if(dc){ handleDragCardClick(dc); return; }

  const dz = e.target.closest('.drop-zone');
  if(dz){ handleDropZoneClick(dz); return; }

  const cb = e.target.closest('.choice-btn');
  if(cb){ handleChoiceClick(cb); return; }
});

/* observer: construye cada ejercicio recién cuando está por entrar en pantalla */
const io = ('IntersectionObserver' in window) ? new IntersectionObserver((entries)=>{
  entries.forEach(en=>{
    if(en.isIntersecting){
      ensureBuilt(parseInt(en.target.dataset.idx,10));
      io.unobserve(en.target);
    }
  });
}, {rootMargin:'300px 0px', threshold:0}) : null;

document.addEventListener('DOMContentLoaded', ()=>{
  buildToc();
  // Ejercicios 1 y 2 son lo primero que se ve: se construyen ya mismo.
  ensureBuilt(1); ensureBuilt(2);
  if(io){
    $all('section.card[data-idx]').forEach(sec=>{
      if(sec.id!=='ej1' && sec.id!=='ej2') io.observe(sec);
    });
  } else {
    // navegadores sin soporte: fallback a construcción inmediata de todo
    for(let i=3;i<=17;i++) ensureBuilt(i);
  }
  updateProgress();
});
</script>
</body>
</html>
